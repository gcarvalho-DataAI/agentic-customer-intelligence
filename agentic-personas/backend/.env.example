APP_NAME=Agentic Customer Intelligence API
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OPENAI_API_KEY=local
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_MODEL=qwen-linkedin
OPENAI_EMBEDDING_MODEL=embed-local
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=700

EMBEDDING_DIM=768

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_customer_intelligence
POSTGRES_USER=aci
POSTGRES_PASSWORD=aci

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=agentic_customer_intelligence
MONGO_COLLECTION=conversations

CLUSTER_PROFILES_PATH=../../ml-clustering/outputs/cluster_profiles.json
KNOWLEDGE_BASE_PATH=../knowledge_base
TOP_K=4
PERSONA_TOP_K_RATIO=0.67
MAX_SHARED_DOCS=1
RECENT_HISTORY_TURNS=2
